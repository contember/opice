{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"types": ["vite/client", "@cloudflare/workers-types"],
		"noEmit": true,
		// App bundle, not a library — no .d.ts emit, so deep inferred types
		// (e.g. the typed RPC client proxy) don't trip the TS2742 portability check.
		"declaration": false,
		"declarationMap": false,
		"allowImportingTsExtensions": false
	},
	"include": ["src/**/*", "vite.config.ts"]
}
